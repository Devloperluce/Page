# ── Supabase (대시보드 → Project Settings → API) ──
SUPABASE_URL=https://xxxxxxxx.supabase.co
# service_role 키: 서버 전용! 절대 클라이언트/깃에 노출 금지
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
# anon(public) 키: 관리자 페이지(/admin) 로그인·조회용. 공개돼도 안전(RLS로 보호)
SUPABASE_ANON_KEY=eyJhbGciOi...

# ── Resend (이메일 발송, https://resend.com) ──
RESEND_API_KEY=re_xxxxxxxx
# 발신 주소: Resend에서 도메인(bigxdata.io) 인증 후 사용
MAIL_FROM=빅스데이터 교육센터 <education@bigxdata.io>
# 새 교육 문의 알림을 받을 담당자 주소
NOTIFY_EMAIL=support@bigxdata.io

# ── 선택 ──
# 소개서 PDF 위치(미지정 시 배포 사이트의 /assets/education-brochure.pdf 사용)
# BROCHURE_URL=https://edu.bigxdata.io/assets/education-brochure.pdf
